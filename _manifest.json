{
  "manifest_version": 2,
  "version": "1.4.0",
  "name": "日期上下文插件",
  "description": "提供 date/date_text 公开 API（仅今天）、query_date 工具（昨天/今天/明天），以及可选的模型请求日期注入（date.inject_on_model_request）",
  "author": {
    "name": "xiexiaojia780",
    "url": "https://github.com/xiexiaojia780"
  },
  "license": "GPL-3.0-or-later",
  "urls": {
    "repository": "https://github.com/xiexiaojia780/date_context_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "cnlunar",
      "version_spec": ">=0.2.4"
    },
    {
      "type": "python_package",
      "name": "chinese-calendar",
      "version_spec": ">=1.11.0"
    }
  ],
  "capabilities": [],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "github.xiexiaojia780.date-context-plugin"
}
